DATABASE_URL="postgresql://user:pass@host:5432/db"

# Enrichment provider (default "grok"):
#   "grok"             → xAI Grok vision
#   "openai"           → OpenAI GPT-4o-mini vision
#   "grok-then-openai" → Grok primary, OpenAI fallback
ENRICH_PROVIDER="grok"

# xAI Grok (required when ENRICH_PROVIDER includes "grok")
XAI_API_KEY=""
XAI_VISION_MODEL="grok-4-1-fast-reasoning"
# XAI_API_BASE="https://api.x.ai/v1"  # uncomment to override

# OpenAI (required when ENRICH_PROVIDER includes "openai")
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"

INGEST_TOKEN="generate-a-long-random-string"
DASHBOARD_PASSWORD="set-a-strong-password"
RETENTION_DAYS="90"
CLEANUP_TOKEN="generate-another-random-string"
