DATABASE_URL="postgresql://user:pass@host:5432/db"

# Enrichment provider:
#   "grok" (default), "openai", "facepp",
#   "grok-then-openai", "grok-then-facepp", "openai-then-facepp",
#   "grok-then-openai-then-facepp"
ENRICH_PROVIDER="grok"

# xAI Grok (used when ENRICH_PROVIDER starts with "grok")
XAI_API_KEY=""
XAI_VISION_MODEL="grok-2-vision-1212"
# XAI_API_BASE="https://api.x.ai/v1"  # uncomment to override

# OpenAI (used when ENRICH_PROVIDER includes "openai")
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"

# Face++ (used when ENRICH_PROVIDER includes "facepp")
FACEPP_API_KEY=""
FACEPP_API_SECRET=""
FACEPP_REGION="us"

INGEST_TOKEN="generate-a-long-random-string"
DASHBOARD_PASSWORD="set-a-strong-password"
RETENTION_DAYS="90"
CLEANUP_TOKEN="generate-another-random-string"
