DATABASE_URL="postgresql://user:pass@host:5432/db"

# Enrichment provider: "openai" (default), "facepp", or "openai-then-facepp".
ENRICH_PROVIDER="openai"

# OpenAI (used when ENRICH_PROVIDER is "openai" or "openai-then-facepp")
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o-mini"

# Face++ (used when ENRICH_PROVIDER is "facepp" or as fallback)
FACEPP_API_KEY=""
FACEPP_API_SECRET=""
FACEPP_REGION="us"

INGEST_TOKEN="generate-a-long-random-string"
DASHBOARD_PASSWORD="set-a-strong-password"
RETENTION_DAYS="90"
CLEANUP_TOKEN="generate-another-random-string"
