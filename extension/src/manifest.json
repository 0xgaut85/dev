{
  "manifest_version": 3,
  "name": "Crunchbase Lead Finder",
  "version": "0.1.0",
  "description": "Scrapes filtered Crunchbase People search results for outreach research.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://www.crunchbase.com/*",
    "https://crunchbase.com/*",
    "https://*.crunchbase.com/*",
    "http://localhost:3000/*",
    "https://*.up.railway.app/*",
    "https://*.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.crunchbase.com/*",
        "https://crunchbase.com/*",
        "https://*.crunchbase.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Crunchbase Lead Finder"
  },
  "icons": {}
}
